SECRET_KEY=change-this-secret
FLASK_DEBUG=1

DB_HOST=db
DB_PORT=3306
DB_NAME=app_db
DB_USER=app_user
DB_PASSWORD=app_password
DB_ROOT_PASSWORD=root_password

# ── 팀원 딥러닝 피부 분석 API (선택사항) ──
# 설정하면 외부 API 우선 사용, 미설정 시 로컬 분석으로 fallback
SKIN_API_URL=
SKIN_API_KEY=
SKIN_API_TIMEOUT=30

# ── 네이버 쇼핑 API (실제 제품 추천) ──
# https://developers.naver.com 에서 앱 등록 후 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
